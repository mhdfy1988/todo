{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "代办",
  "version": "0.1.1",
  "identifier": "com.luoji.zuoban.spike",
  "build": {
    "frontendDist": "../desktop"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "代办",
        "width": 310,
        "height": 92,
        "minWidth": 72,
        "minHeight": 92,
        "resizable": false,
        "fullscreen": false,
        "maximized": false,
        "visible": false,
        "focus": false,
        "focusable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost; img-src 'self' asset: data:; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg3NTkwRjRCNjgzNTc3MEQKUldRTmR6Vm9TdzlaaDFORi9rbDdkaUpEZlhsdm1ZR2pQRm1XTGVOM0pubHcwMmY3SFJxdGQxRGQK",
      "endpoints": [
        "https://github.com/mhdfy1988/todo/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
